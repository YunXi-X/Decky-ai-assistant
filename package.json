{
  "name": "decky-ai-chat",
  "version": "0.1.0",
  "description": "AI chat panel for Steam Deck game mode via Decky Loader.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "vendor:claude": "python3 scripts/vendor_claude_code.py",
    "package:release": "pnpm run build && python3 scripts/package_release.py",
    "package:release-folder": "pnpm run build && python3 scripts/package_release.py --folder-wrapper",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "decky",
    "steam-deck",
    "ai",
    "chat"
  ],
  "author": "Decky AI Assistant Contributors",
  "license": "MIT",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "@types/katex": "^0.16.8",
    "katex": "^0.17.0",
    "qrcode": "^1.5.4",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
